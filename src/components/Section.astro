---
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";

interface Props {
  heading: string;
  subheading?: string;
  buttonText?: string;
  buttonLink?: string;
  buttonTarget?: string;
  button2Text?: string;
  button2Link?: string;
  button2Target?: string;
  imageSrc?: ImageMetadata;
  imageAlt?: string;
}

const {
  heading,
  subheading,
  buttonText,
  buttonLink,
  buttonTarget,
  button2Text,
  button2Link,
  button2Target,
  imageSrc,
  imageAlt,
} = Astro.props;
---

<article class="section-card">
  <div class="section-content">
    <h2>{heading}</h2>
    {subheading && <p>{subheading}</p>}
    {
      (buttonText || button2Text) && (
        <div class="section-buttons">
          {buttonText && (
            <a href={buttonLink} target={buttonTarget} class="btn">
              {buttonText}
            </a>
          )}
          {button2Text && (
            <a
              href={button2Link}
              target={button2Target}
              class="btn btn-secondary"
            >
              {button2Text}
            </a>
          )}
        </div>
      )
    }
  </div>
  {
    imageSrc && (
      <div class="section-image">
        <Picture
          src={imageSrc}
          alt={imageAlt ?? heading}
          layout="constrained"
          width={542}
          height={304}
          formats={["avif", "webp"]}
          quality="high"
        />
      </div>
    )
  }
</article>
<style>
  .section-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);

    &:not(:has(.section-image)) {
      grid-template-columns: 1fr;
    }

    &:first-child {
      padding-top: 0;
    }

    &:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    &:nth-child(even) {
      direction: rtl;
    }

    &:nth-child(even) > * {
      direction: ltr;
    }

    h2 {
      margin-bottom: 1rem;
    }

    p {
      margin-bottom: 0;
    }

    p:not(:last-child) {
      margin-bottom: 1.5rem;
    }
  }

  .section-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-image {
    background-color: var(--color-bg-secondary);
    border-radius: 12px;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    border: 1px solid var(--color-border);

    picture {
      width: 100%;
      height: 100%;
    }

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 12px;
    }
  }

  @media (max-width: 900px) {
    .section-card {
      gap: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .section-card {
      grid-template-columns: 1fr;
      gap: 2rem;

      &:nth-child(even) {
        direction: ltr;
      }
    }

    .section-image {
      order: -1;
    }
  }
</style>
