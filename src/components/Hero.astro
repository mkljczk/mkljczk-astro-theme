---
const { heading, subheading } = Astro.props;
---

<section class="hero">
  <div class="container">
    <h1>{heading}</h1>
    <p>{subheading}</p>
  </div>
</section>
<style>
  .hero {
    padding: 3rem 2rem;
    text-align: center;
    background-color: var(--color-bg-secondary);

    h1 {
      font-size: 3rem;
      margin-bottom: 1.5rem;
    }

    p {
      font-size: 1.25rem;
      max-width: 900px;
      margin: 0 auto;
      white-space: pre-wrap;
    }
  }

  @media (max-width: 900px) {
    .hero h1 {
      font-size: 2.25rem;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 2.5rem 1.5rem;

      h1 {
        font-size: 1.875rem;
      }
    }
  }
</style>
