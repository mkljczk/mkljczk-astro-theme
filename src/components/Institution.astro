---
interface Props {
  title?: string;
  description?: string;
  href?: string;
  hrefText?: string;
  hrefAlt?: string;
  hrefTextAlt?: string;
}

const { title, description, href, hrefText, hrefAlt, hrefTextAlt } = Astro.props;
---

<div class="institution-card">
  {
    title ? (
      <h3 set:html={title} />
    ) : (
      <h3>
        <slot name="title" />
      </h3>
    )
  }
  <slot />
  <p>{description}</p>

  {href && (
    <a class={hrefAlt ? "btn btn-sm" : "btn btn-secondary btn-sm"} href={href} target="_blank" rel="noopener noreferrer">
      {hrefText || href}
    </a>
  )}
  {hrefAlt && (
    <a class="btn btn-secondary btn-sm" href={hrefAlt} target="_blank" rel="noopener noreferrer">
      {hrefTextAlt || hrefAlt}
    </a>
  )}
</div>
<style>
  .institution-card {
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-sm);

    h3 {
      margin-top: 0;
      margin-bottom: 0.75rem;
    }

    p {
      margin-bottom: 0;
    }

    .btn {
      margin-top: 0.5rem;
    }

    .btn + .btn {
      margin-left: 0.5rem;
    }

    @media (max-width: 600px) {
      padding: 1rem;
    }
  }
</style>
