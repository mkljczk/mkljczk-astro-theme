---
interface NavItem {
  label: string;
  href: string;
  target?: string;
}

interface DocsNavItem {
  id: string;
  data: { title: string };
}

interface DocsNavSection {
  name: string;
  items: DocsNavItem[];
}

interface Props {
  siteTitle: string;
  homeHref?: string;
  navItems?: NavItem[];
  menuExpandTitle: string;
  menuCollapseTitle: string;
  docsNav?: DocsNavSection[];
  docsHomeHref?: string;
}

const {
  siteTitle,
  homeHref = "/",
  navItems,
  menuExpandTitle,
  menuCollapseTitle,
  docsNav,
  docsHomeHref = "/docs/",
} = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <a href={homeHref} class="logo">{siteTitle}</a>
    {
      navItems && navItems.length > 0 && (
        <>
          <button
            class="hamburger"
            title={menuExpandTitle}
            data-expand-title={menuExpandTitle}
            data-collapse-title={menuCollapseTitle}
            aria-expanded="false"
          >
            <span class="hamburger-line" />
            <span class="hamburger-line" />
            <span class="hamburger-line" />
          </button>
          <nav class="main-nav">
            <ul>
              {navItems.map((item) => (
                <li>
                  <a href={item.href} target={item.target}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
            {docsNav && docsNav.length > 0 && (
              <div class="mobile-docs-nav">
                {docsNav.map(({ name, items }) => (
                  <div class="mobile-docs-section">
                    <span class="mobile-docs-section-title">{name}</span>
                    <ul>
                      {items.map((doc) => (
                        <li>
                          <a href={`${docsHomeHref}${doc.id}/`}>
                            {doc.data.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            )}
          </nav>
        </>
      )
    }
  </div>
</header>

<script>
  const hamburger = document.querySelector(".hamburger");
  const nav = document.querySelector(".main-nav");

  hamburger?.addEventListener("click", () => {
    const isExpanded = hamburger.getAttribute("aria-expanded") === "true";
    hamburger.setAttribute("aria-expanded", (!isExpanded).toString());
    hamburger.setAttribute(
      "title",
      isExpanded
        ? hamburger.getAttribute("data-expand-title")!
        : hamburger.getAttribute("data-collapse-title")!,
    );
    if (!isExpanded) {
      hamburger.classList.add("open");
      nav?.classList.add("opening");
      setTimeout(() => {
        nav?.classList.add("open");
      }, 0);
    } else {
      hamburger.classList.remove("open");
      nav?.classList.remove("open");
      const handleAnimationEnd = () => {
        nav?.classList.remove("opening");
        nav?.removeEventListener("animationend", handleAnimationEnd);
      };
      if (nav) nav.addEventListener("animationend", handleAnimationEnd);
    }
  });
</script>
<style>
  .site-header {
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .main-nav ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    text-align: center;
  }

  .main-nav a {
    color: var(--color-text-secondary);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .main-nav a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 101;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .hamburger.open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 720px) {
    .hamburger {
      display: flex;
    }

    .main-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--color-bg);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 2rem;
      display: none;
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 0.3s ease-in-out;
      overflow-y: auto;
      max-height: calc(100vh - 4rem);

      &.opening {
        display: block;
      }

      &.open {
        transform: scaleY(1);
      }

      ul {
        flex-direction: column;
        gap: 1rem;
        align-items: center;
      }
    }

    .main-nav:has(.mobile-docs-nav) ul {
      gap: 0.5rem;
      text-align: left;
      align-items: flex-start;

      a {
        padding: 0.3rem 0;
      }
    }
  }

  .mobile-docs-nav {
    display: block;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.875rem;
  }

  .mobile-docs-home {
    display: block;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
    padding: 0.375rem 0;
    margin-bottom: 0.75rem;

    &:hover {
      color: var(--color-accent);
      text-decoration: none;
    }
  }

  .mobile-docs-section {
    margin-bottom: 1rem;
  }

  .mobile-docs-section-title {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: 0.375rem;
  }

  .mobile-docs-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
    flex-direction: column;
    gap: 0;
    align-items: flex-start;
  }

  .mobile-docs-section li a {
    display: block;
    padding: 0.3rem 0;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.875rem;

    &:hover {
      color: var(--color-accent);
    }
  }

  @media (min-width: 721px) {
    .mobile-docs-nav,
    .mobile-docs-home,
    .mobile-docs-section,
    .mobile-docs-section-title {
      display: none;
    }
  }
</style>
