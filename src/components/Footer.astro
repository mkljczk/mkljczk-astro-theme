---
interface FooterLink {
  label: string;
  href: string;
  target?: string;
}

interface FooterSocialLink {
  label: string;
  href: string;
  icon: any;
}

interface Props {
  links: FooterLink[];
  copyText: string;
  socialLinks?: FooterSocialLink[];
  withTransFlag?: boolean;
}

const {
  links,
  copyText,
  socialLinks = [],
  withTransFlag = false,
} = Astro.props;
---

<footer class="site-footer">
  <div class="footer-inner">
    {
      socialLinks.length > 0 && (
        <div class="footer-social" aria-label="Social media links">
          {socialLinks.map(({ label, href, icon: Icon }) => (
            <a
              href={href}
              target="_blank"
              rel="me noopener noreferrer"
              aria-label={label}
              title={label}
            >
              <Icon />
            </a>
          ))}
        </div>
      )
    }
    <div class="footer-top">
      <div class="footer-links">
        {
          links.map((link) => (
            <a href={link.href} target={link.target}>
              {link.label}
            </a>
          ))
        }
      </div>
      <div class="footer-copy">
        {copyText}
        {withTransFlag && <span aria-hidden="true"> 🏳️‍⚧️</span>}
      </div>
    </div>
    {
      Astro.slots.has("license") && (
        <div class="footer-license">
          <slot name="license" />
        </div>
      )
    }
  </div>
</footer>
<style>
  .site-footer {
    background-color: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    padding: 3rem 2rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    margin: 0 0.5rem;
    gap: 0.75rem;

    a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--color-bg-secondary);
      transition: background-color 0.2s ease;
      padding: 0.5rem;
      background: var(--color-text-secondary);
      border-radius: 50%;

      &:hover {
        background-color: var(--color-accent);
      }
    }

    svg {
      width: 1.5rem;
      height: 1.5rem;
    }
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-links {
    display: flex;
    gap: 2rem;

    a {
      color: var(--color-text-secondary);
      font-size: 0.9rem;

      &:hover {
        color: var(--color-accent);
      }
    }
  }

  .footer-copy {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  .footer-license {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    text-align: center;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);

    a {
      color: var(--color-text-secondary);
      text-decoration: underline;
      text-underline-offset: 2px;

      &:hover {
        color: var(--color-accent);
      }
    }
  }

  @media (max-width: 600px) {
    .footer-top {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .footer-links {
      flex-direction: column;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }

    .footer-copy {
      padding-top: 1rem;
      width: 100%;
      border-top: 1px solid var(--color-border);
    }
  }
</style>
