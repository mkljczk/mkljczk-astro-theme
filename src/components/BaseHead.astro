---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";
import type { ImageMetadata } from "astro";

interface Props {
  siteTitle: string;
  title?: string;
  description?: string;
  image?: ImageMetadata;
  faviconPath?: string;
  sitemapPath?: string;
  rssPath?: string;
  rssTitle?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  siteTitle,
  title,
  description,
  image,
  faviconPath,
  sitemapPath = "/sitemap-index.xml",
  rssPath = "rss.xml",
  rssTitle,
} = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
{faviconPath && <link rel="icon" type="image/svg+xml" href={faviconPath} />}
<link rel="sitemap" href={sitemapPath} />
<link
  rel="alternate"
  type="application/rss+xml"
  title={rssTitle ?? siteTitle}
  href={new URL(rssPath, Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title ? `${title} | ${siteTitle}` : siteTitle}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title ?? siteTitle} />
{description && <meta property="og:description" content={description} />}
{image && <meta property="og:image" content={new URL(image.src, Astro.url)} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title ?? siteTitle} />
{description && <meta property="twitter:description" content={description} />}
{
  image && (
    <meta property="twitter:image" content={new URL(image.src, Astro.url)} />
  )
}
<slot />
