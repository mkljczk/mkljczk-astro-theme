---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"] & {
  lang: string;
  backToBlogText: string;
  backToBlogHref: string;
  updatedOnText: string;
};

const {
  title,
  pubDate,
  updatedDate,
  heroImage,
  lang,
  backToBlogText,
  backToBlogHref,
  updatedOnText,
} = Astro.props;
---

<html lang={lang}>
  <head>
    <slot name="head" />
    <style>
      .blog-meta {
        font-size: 0.875rem;
        color: var(--color-text-secondary);

        time {
          color: var(--color-accent);
        }
      }

      .blog-article {
        padding: 3rem 0 4rem;

        .container {
          max-width: var(--content-width);
        }
      }
      .article-header {
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--color-border);

        h1 {
          margin-bottom: 0;
          margin-top: 0.75rem;
        }
      }

      .article-content {
        line-height: 1.8;

        p {
          margin-bottom: 1.5rem;
        }

        h2 {
          margin-top: 2.5rem;
          margin-bottom: 1rem;
          padding-top: 1.5rem;
          border-top: 1px solid var(--color-border);
        }
      }

      .article-footer {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
      }
    </style>
  </head>

  <body>
    <slot name="header" />
    <main>
      <article class="blog-article">
        <div class="container">
          <header class="article-header">
            <div class="blog-meta">
              <FormattedDate date={pubDate} lang={lang} />
              {
                updatedDate && (
                  <div class="last-updated-on">
                    {updatedOnText}{" "}
                    <FormattedDate date={updatedDate} lang={lang} />
                  </div>
                )
              }
            </div>
            <h1>{title}</h1>
            {
              heroImage && (
                <div class="hero-image">
                  <Image width={1020} height={510} src={heroImage} alt="" />
                </div>
              )
            }
          </header>
          <div class="article-content">
            <slot />
          </div>
          <footer class="article-footer">
            <a href={backToBlogHref} class="btn btn-sm btn-secondary"
              ><span aria-hidden="true">←</span> {backToBlogText}</a
            >
          </footer>
        </div>
      </article>
    </main>
    <slot name="footer" />
  </body>
</html>
